        <shape>
            <solid android:color="#1565C0"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- normalny -->
    <item>
        <shape>
            <solid android:color="#1976D2"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>