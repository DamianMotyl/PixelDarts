<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GRACZE:"
            android:textStyle="bold"
            android:layout_marginRight="10dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEndGame"
            style="@style/ModernButton"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="100dp"
            android:layout_weight="1"
            android:background="@drawable/btn_red"
            android:text="Koniec gry" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddAnotherPlayer"
            style="@style/ModernButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/btn_blue"
            android:text="Dodaj gracza" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutAllScores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:background="#CFD8DC"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp"
        android:layout_marginTop="5dp">

        <TextView
            android:id="@+id/tvCurrentPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gracz 1"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="301"
            android:textSize="80sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvTurnCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tura: _ , _ , _"
            android:textSize="20sp"
            android:textColor="#546E7A" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="5dp">

        <androidx.appcompat.widget.AppCompatButton
            style="@style/ModernButton"
            android:id="@+id/btnDouble"
            android:background="@drawable/btn_blue"
            android:layout_width="0dp"
            android:layout_weight="0.7"
            android:layout_height="60dp"
            android:text="x2"/>

        <androidx.appcompat.widget.AppCompatButton
            style="@style/ModernButton"
            android:id="@+id/btnTriple"
            android:background="@drawable/btn_blue"
            android:layout_width="0dp"
            android:layout_weight="0.7"
            android:layout_height="60dp"
            android:text="x3"/>

        <androidx.appcompat.widget.AppCompatButton
            style="@style/ModernButton"
            android:id="@+id/btnMiss"
            android:background="@drawable/btn_red"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:text="MISS"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <androidx.appcompat.widget.AppCompatButton
            style="@style/ModernButton"
            android:id="@+id/btnConfirmTurn"
            android:background="@drawable/btn_green"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1.3"
            android:text="ZATWIERDŹ"
            android:textSize="18dp"/>

        <androidx.appcompat.widget.AppCompatButton
            style="@style/ModernButton"
            android:id="@+id/btnUndo"
            android:background="@drawable/btn_red"
            android:layout_width="0dp"
            android:layout_weight="1.3"
            android:layout_height="60dp"
            android:text="COFNIJ"
            android:textSize="18dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:background="#FFFFFF">

        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/gridPoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            app:columnCount="5" />
    </ScrollView>

</LinearLayout>